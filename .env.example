# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Source platform (read-only sync source) ────────────────────────────────
# The build3 founders-directory-platform. We only ever READ from it.
SOURCE_API_BASE=https://platform.build3.in
SOURCE_API_KEY=your-source-x-api-key   # equals the platform's SESSION_SECRET

# ─── Supabase (our system of record) ────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # service role — server side only
SUPABASE_AVATAR_BUCKET=avatars

# ─── OpenAI (conversational engine + match scorer) ──────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# ─── Meta WhatsApp Cloud API ────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=choose-a-random-string        # for GET /webhook handshake
WHATSAPP_APP_SECRET=your-meta-app-secret            # for X-Hub-Signature-256
WHATSAPP_TOKEN=your-permanent-access-token           # graph API bearer token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_GRAPH_VERSION=v21.0

# ─── Sync schedule ──────────────────────────────────────────────────────────
SYNC_CRON=0 */6 * * *        # every 6 hours
SYNC_ON_BOOT=true            # run one sync at startup
